<!DOCTYPE html>
<html lang="en">

<head>
    <title>Edit Movie</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <div class="form-container">
        <div class="form-card">
            <h1>Edit Movie</h1>

            <form action="/update-movie/<%= movie._id %>" method="POST" enctype="multipart/form-data">
                <input type="text" name="movieName" value="<%= movie.movieName %>" required>

                <textarea name="description" required><%= movie.description %></textarea>

                <input type="number" name="year" value="<%= movie.year %>" required>

                <input type="text" name="category" value="<%= movie.category %>" required>

                <input type="file" name="image">

                <button type="submit">Update Movie</button>
            </form>
        </div>
    </div>

</body>

</html>